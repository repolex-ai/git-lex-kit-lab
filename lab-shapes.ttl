@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix lab:     <https://repolex.ai/ontology/kit/lex-lab/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .

# =============================================================================
# LEX-LAB KIT SHACL SHAPES
# =============================================================================
# Validates lex-lab kit documents against the lab ontology.
# Run via: rudof validate --shapes lab-shapes.ttl --data <file.ttl>
# =============================================================================


# --- Investigation ---

lab:InvestigationShape a sh:NodeShape ;
    sh:targetClass lab:Investigation ;
    sh:property [
        sh:path lab:researchQuestion ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "Investigation must have a researchQuestion." ;
    ] ;
    sh:property [
        sh:path lab:investigationStatus ;
        sh:in ( "open" "active" "paused" "concluded" "abandoned" ) ;
        sh:minCount 1 ;
        sh:message "investigationStatus must be 'open', 'active', 'paused', 'concluded', or 'abandoned'." ;
    ] ;
    sh:property [
        sh:path lab:lead ;
        sh:nodeKind sh:IRI ;
        sh:message "lead must be an IRI reference to the leading agent." ;
    ] ;
    sh:property [
        sh:path lab:contributors ;
        sh:nodeKind sh:IRI ;
        sh:message "contributors must be IRI references to agents." ;
    ] ;
    sh:property [
        sh:path lab:parentInvestigation ;
        sh:nodeKind sh:IRI ;
        sh:message "parentInvestigation must be an IRI reference to a lab:Investigation." ;
    ] ;
    sh:property [
        sh:path lab:concludedBy ;
        sh:nodeKind sh:IRI ;
        sh:message "concludedBy must be an IRI reference to a lab:Synthesis." ;
    ] .


# --- Hypothesis ---

lab:HypothesisShape a sh:NodeShape ;
    sh:targetClass lab:Hypothesis ;
    sh:property [
        sh:path lab:claim ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "Hypothesis must have a claim — the falsifiable statement being evaluated." ;
    ] ;
    sh:property [
        sh:path lab:hypothesisStatus ;
        sh:in ( "proposed" "active" "supported" "refuted" "revised" "abandoned" ) ;
        sh:minCount 1 ;
        sh:message "hypothesisStatus must be 'proposed', 'active', 'supported', 'refuted', 'revised', or 'abandoned'." ;
    ] ;
    sh:property [
        sh:path lab:confidence ;
        sh:in ( "speculative" "plausible" "likely" "supported" "refuted" ) ;
        sh:message "confidence must be 'speculative', 'plausible', 'likely', 'supported', or 'refuted'." ;
    ] ;
    sh:property [
        sh:path lab:revisedBy ;
        sh:nodeKind sh:IRI ;
        sh:message "revisedBy must be an IRI reference to a lab:Hypothesis." ;
    ] ;
    sh:property [
        sh:path lab:addresses ;
        sh:nodeKind sh:IRI ;
        sh:message "addresses must be an IRI reference to a lab:Investigation." ;
    ] .


# --- Experiment ---

lab:ExperimentShape a sh:NodeShape ;
    sh:targetClass lab:Experiment ;
    sh:property [
        sh:path lab:protocol ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "Experiment must have a protocol describing what was done." ;
    ] ;
    sh:property [
        sh:path lab:experimentStatus ;
        sh:in ( "planned" "running" "complete" "failed" "abandoned" ) ;
        sh:minCount 1 ;
        sh:message "experimentStatus must be 'planned', 'running', 'complete', 'failed', or 'abandoned'." ;
    ] ;
    sh:property [
        sh:path lab:tests ;
        sh:nodeKind sh:IRI ;
        sh:message "tests must be an IRI reference to a lab:Hypothesis." ;
    ] ;
    sh:property [
        sh:path lab:partOf ;
        sh:nodeKind sh:IRI ;
        sh:message "partOf must be an IRI reference to a lab:Investigation." ;
    ] ;
    sh:property [
        sh:path lab:replicates ;
        sh:nodeKind sh:IRI ;
        sh:message "replicates must be an IRI reference to a lab:Experiment." ;
    ] ;
    sh:property [
        sh:path lab:runBy ;
        sh:nodeKind sh:IRI ;
        sh:message "runBy must be an IRI reference to an agent." ;
    ] ;
    sh:property [
        sh:path lab:dataset ;
        sh:nodeKind sh:IRI ;
        sh:message "dataset must be an IRI reference." ;
    ] .


# --- Survey ---

lab:SurveyShape a sh:NodeShape ;
    sh:targetClass lab:Survey ;
    sh:property [
        sh:path lab:scope ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "Survey must have a scope describing what was surveyed." ;
    ] ;
    sh:property [
        sh:path lab:surveyStatus ;
        sh:in ( "planned" "in-progress" "complete" ) ;
        sh:minCount 1 ;
        sh:message "surveyStatus must be 'planned', 'in-progress', or 'complete'." ;
    ] ;
    sh:property [
        sh:path lab:informs ;
        sh:nodeKind sh:IRI ;
        sh:message "informs must be an IRI reference to a lab:Investigation." ;
    ] .


# --- Synthesis ---

lab:SynthesisShape a sh:NodeShape ;
    sh:targetClass lab:Synthesis ;
    sh:property [
        sh:path lab:synthesizedClaim ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "Synthesis must have a synthesizedClaim — the central citable statement." ;
    ] ;
    sh:property [
        sh:path lab:synthesisStatus ;
        sh:in ( "draft" "review" "published" "superseded" ) ;
        sh:minCount 1 ;
        sh:message "synthesisStatus must be 'draft', 'review', 'published', or 'superseded'." ;
    ] ;
    sh:property [
        sh:path lab:evidenceStrength ;
        sh:in ( "weak" "moderate" "strong" "conclusive" ) ;
        sh:message "evidenceStrength must be 'weak', 'moderate', 'strong', or 'conclusive'." ;
    ] ;
    sh:property [
        sh:path lab:concludes ;
        sh:nodeKind sh:IRI ;
        sh:message "concludes must be an IRI reference to a lab:Investigation." ;
    ] ;
    sh:property [
        sh:path lab:basedOn ;
        sh:nodeKind sh:IRI ;
        sh:message "basedOn must be IRI references to experiments or surveys." ;
    ] ;
    sh:property [
        sh:path lab:supports ;
        sh:nodeKind sh:IRI ;
        sh:message "supports must be an IRI reference to a lab:Hypothesis." ;
    ] ;
    sh:property [
        sh:path lab:refutes ;
        sh:nodeKind sh:IRI ;
        sh:message "refutes must be an IRI reference to a lab:Hypothesis." ;
    ] ;
    sh:property [
        sh:path lab:supersedes ;
        sh:nodeKind sh:IRI ;
        sh:message "supersedes must be an IRI reference to a lab:Synthesis." ;
    ] ;
    sh:property [
        sh:path lab:authors ;
        sh:nodeKind sh:IRI ;
        sh:message "authors must be IRI references to agents." ;
    ] .


# --- Deliberation ---

lab:DeliberationShape a sh:NodeShape ;
    sh:targetClass lab:Deliberation ;
    sh:property [
        sh:path lab:deliberationStatus ;
        sh:in ( "open" "converging" "concluded" "deadlocked" ) ;
        sh:minCount 1 ;
        sh:message "deliberationStatus must be 'open', 'converging', 'concluded', or 'deadlocked'." ;
    ] ;
    sh:property [
        sh:path lab:outcome ;
        sh:in ( "consensus" "dissensus" "deferred" "merged" ) ;
        sh:message "outcome must be 'consensus', 'dissensus', 'deferred', or 'merged'." ;
    ] ;
    sh:property [
        sh:path lab:regarding ;
        sh:nodeKind sh:IRI ;
        sh:message "regarding must be an IRI reference to a hypothesis or investigation." ;
    ] ;
    sh:property [
        sh:path lab:producedSynthesis ;
        sh:nodeKind sh:IRI ;
        sh:message "producedSynthesis must be an IRI reference to a lab:Synthesis." ;
    ] .


# --- ResearchBranch ---

lab:ResearchBranchShape a sh:NodeShape ;
    sh:targetClass lab:ResearchBranch ;
    sh:property [
        sh:path lab:branchName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "ResearchBranch must have a branchName." ;
    ] ;
    sh:property [
        sh:path lab:embodiesHypothesis ;
        sh:nodeKind sh:IRI ;
        sh:message "embodiesHypothesis must be an IRI reference to a lab:Hypothesis." ;
    ] .
